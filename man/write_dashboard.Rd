\name{write_dashboard}
\alias{write_dashboard}
\title{Write a BlinkDash project}
\usage{
write_dashboard(manifest, project_dir)
}
\arguments{
\item{manifest}{Dashboard manifest list.}
\item{project_dir}{Project directory.}
}
\value{
Paths to the written files, invisibly.
}
\description{
Writes both the human-readable YAML project file and a JSON mirror.
}
